PORT=3000

# External logs API (handles DB persistence on its side)
# Base URL only - the paths below are appended automatically
LOGS_API_BASE_URL=https://your-api-host.example.com

# Login endpoint used to obtain a bearer token (email/password -> { "token": "..." })
LOGS_API_LOGIN_URL=https://your-api-host.example.com/api/auth/login
LOGS_API_EMAIL=your_service_account_email
LOGS_API_PASSWORD=your_service_account_password
